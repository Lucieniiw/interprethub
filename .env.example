PORT=8082
# If dev shows "Port ... is already in use", another API is bound here (duplicate `pnpm run dev` or old process). Stop it or pick a new PORT and match `client/.env.development` if you set VITE_API_PROXY_TARGET there.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/interpret_hub
JWT_SECRET=replace-with-long-random-string-at-least-32-chars
# Session JWT lifetime (invite/password links are fixed at 12h in code). Examples: 8h, 24h, 7d
# JWT_EXPIRES_IN=7d

# Browser origin(s) allowed for CORS and Socket.IO. In production this is required (comma-separated for multiple).
FRONTEND_ORIGIN=http://localhost:5175

# Optional: claim/decline email token lifetime (default 7d). Invite/password reset links are always 12h.
# JOB_ACTION_TOKEN_EXPIRES_IN=7d
# Optional — public URL users click from email (defaults to FRONTEND_ORIGIN). Use your live app URL in production so claim/decline links resolve.
# PUBLIC_APP_URL=https://app.example.org

# Public origin of the HTTP API (signed attachment/profile URLs, absolute links when the SPA is on another host). Defaults to PUBLIC_APP_URL, then the first FRONTEND_ORIGIN entry.
# API_PUBLIC_URL=https://api.example.org

# Optional — separate HMAC secret for upload read tokens (defaults to JWT_SECRET).
# UPLOAD_READ_SECRET=long-random-string

# Client (Vite): set VITE_API_URL in production when the browser calls the API on a different host; it is merged into the built CSP connect-src. Dev usually omits this and proxies /api via Vite.
# VITE_API_URL=https://api.example.org

# Set to 1 when the API sits behind a reverse proxy so Express sees real client IPs (rate limits, logs). Use only with a correctly configured proxy; wrong settings let clients spoof X-Forwarded-For.
# TRUST_PROXY=1

# One-time: create two SUPER_ADMIN users. Either set in shell (see scripts/bootstrap-production-super-admins.ts) or add InterpretHub/.env.bootstrap.local (gitignored) with BOOTSTRAP_SUPERADMIN_1_PASSWORD and BOOTSTRAP_SUPERADMIN_2_PASSWORD, then `pnpm run bootstrap:super-admins`.

# Email (SendGrid SMTP — copy to `.env` and use your real API key; never commit `.env`)
# Create an API key in SendGrid with Mail Send permission. Use verified sender for SMTP_FROM.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key-here
SMTP_FROM=no-reply@iiwisconsin.org
# Production: if SMTP_HOST is set, SMTP_FROM must be set (API exits at startup otherwise).

# Optional: set to 1 for verbose nodemailer SMTP logs while debugging
# SMTP_DEBUG=1

# Transactional email branding (invitation, password reset, job emails)
# Defaults match IIW navy/teal; optional EMAIL_LOGO_URL for hosted logo (HTTPS recommended).
EMAIL_BRAND_NAME=InterpreterHub
EMAIL_BRAND_ORG=International Institute of Wisconsin
EMAIL_COLOR_PRIMARY=#1B4F72
EMAIL_COLOR_ACCENT=#0E7490
EMAIL_SUPPORT_EMAIL=interpretation@iiwisconsin.org
# EMAIL_LOGO_URL=https://your-domain.org/email-brand.svg

# Reminder emails / in-app (Settings → Notifications → Reminder). Scheduler runs in the API process.
# DISABLE_REMINDER_DISPATCH=1
# REMINDER_DISPATCH_INTERVAL_MS=300000
