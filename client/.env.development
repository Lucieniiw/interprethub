# Vite `/api` proxy — must match the API (repo root `.env` PORT, default 8082). Use 127.0.0.1 to avoid Windows localhost → IPv6 proxy errors.
VITE_API_PROXY_TARGET=http://127.0.0.1:8082

# Vite dev server port — align root `.env` FRONTEND_ORIGIN (e.g. http://localhost:5175)
VITE_DEV_SERVER_PORT=5175
